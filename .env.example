# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

OLLAMA_MODEL=qwen3:4b
API_PORT=8090
TZ=Europe/Madrid

# IP a la que se vinculan los puertos Docker.
# En servidor doméstico: pon tu IP LAN (ej. <SERVER_IP>) para no exponerlos a 0.0.0.0
BIND_IP=0.0.0.0

# Secreto compartido entre NPM y la API (ver SEGURIDAD.md)
MIPIZARRA_INTERNAL_SECRET=

# Secret key de Django (genera uno con: python -c "import secrets; print(secrets.token_hex(50))")
DJANGO_SECRET_KEY=
